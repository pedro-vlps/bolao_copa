{
  "name": "bolao-copa",
  "version": "1.0.0",
  "private": true,
  "description": "API para bolao da Copa do Mundo com grupos, palpites e ranking.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "bootstrap": "tsx src/scripts/bootstrap.ts",
    "typecheck": "tsc --noEmit",
    "setup": "tsx src/scripts/setup.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.32",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
